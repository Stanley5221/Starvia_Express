# Expo web on THIS computer:
EXPO_PUBLIC_API_URL=http://localhost:4000

# Physical phone on same Wi-Fi (run `ipconfig`, use IPv4 Address):
# EXPO_PUBLIC_API_URL=http://192.168.1.100:4000

# Public Mapbox token (pk.ey...) — used at runtime for map tiles and directions
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your_public_token_here

# Secret Mapbox download token (sk.ey... with DOWNLOADS:READ scope)
# Needed only for native builds (EAS Build / expo run:android)
# Get it at: https://account.mapbox.com/access-tokens/ → Create token → DOWNLOADS:READ
# For EAS Build, set this as an EAS secret instead: eas secret:create ...
MAPBOX_DOWNLOADS_TOKEN=sk.your_secret_download_token_here
