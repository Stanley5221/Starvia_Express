# Copy this file to .env and fill in the values.
# NEVER commit your actual .env to version control.

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/deliverydb"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_USE_A_LONG_RANDOM_STRING"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ─── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL="https://your-web-app.com"
ADMIN_URL="https://admin.your-web-app.com"

# ─── Admin Seed ───────────────────────────────────────────────────────────────
# Use a strong random string — only used once to create the first admin account
ADMIN_SEED_SECRET="CHANGE_ME_STRONG_RANDOM_STRING"
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="CHANGE_ME_STRONG_PASSWORD"

# ─── Email (Nodemailer) ────────────────────────────────────────────────────────
# Gmail: EMAIL_HOST=smtp.gmail.com, PORT=587, SECURE=false
# Use a Gmail App Password: myaccount.google.com/apppasswords
# Sendgrid: EMAIL_HOST=smtp.sendgrid.net, PORT=587, USER=apikey, PASS=<API_KEY>
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=Starvia Express
